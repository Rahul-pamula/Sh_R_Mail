# ========================================================
# ENVIRONMENT CONFIGURATION — TEMPLATE
# Copy this file to .env and fill in all values.
# Run: cp .env.example .env
# ========================================================

# ── Supabase (Database & Auth Roles) ──────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ── RabbitMQ (Message Queue) ─────────────────────────────────────────────
RABBITMQ_URL=

# ── SMTP Settings (Amazon SES / Mailtrap) ───────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# ── AWS SDK Credentials (Direct API Access) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# ── Social Logins (Google / GitHub) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Redis (Campaign State + Rate Limiting) ───────────────────────────────
REDIS_URL=

# ── JWT Auth & Security Secrets ─────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
UNSUBSCRIBE_SECRET=
TRACKING_SECRET=

# ── App URLs & Network routing ────────────────────────────────────────────────────────
# Your main frontend URL (CORS / Unsubscribe redirects)
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# Backend references from Worker/UI
API_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000

# ── App Environment Settings ───────────────────────────────────────
ENV=development
ENVIRONMENT=development
DEBUG=True
TRACE_ID_HEADER=X-Trace-ID

# Note: CLERK_PUBLISHABLE_KEY and CLERK_SECRET_KEY have been removed because 
# the system uses a custom JWT/Supabase auth stack natively now.
